# PostgreSQL dari Railway / Neon / Supabase
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret untuk cookie session (generate dengan: openssl rand -base64 32)
SESSION_SECRET="ganti-dengan-random-string-panjang"

# URL aplikasi (contoh Vercel)
NEXTAUTH_URL="https://nama-app.vercel.app"
